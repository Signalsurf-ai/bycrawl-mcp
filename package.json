{
  "name": "@bycrawl/mcp",
  "version": "0.4.0",
  "description": "MCP server for ByCrawl — query 9+ social media platforms (Threads, X, Facebook, Reddit, LinkedIn, Xiaohongshu, TikTok, Instagram, YouTube) from AI agents",
  "type": "module",
  "bin": {
    "bycrawl-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "TRANSPORT=http tsx src/index.ts",
    "start": "node build/index.js",
    "start:http": "TRANSPORT=http node build/index.js",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "test:smoke-http": "vitest run tests/smoke-http.test.ts",
    "test:unit": "vitest run tests/client.unit.test.ts",
    "test:integration": "vitest run tests/platforms/",
    "test:integration:slow": "INCLUDE_SLOW=true vitest run tests/platforms/",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "social-media",
    "threads",
    "twitter",
    "facebook",
    "reddit",
    "linkedin",
    "xiaohongshu",
    "tiktok",
    "instagram",
    "ai",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SignalsurfAi/bycrawl-mcp"
  },
  "homepage": "https://bycrawl.com",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
